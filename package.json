    "start:mcp": "node src/server.mjs"
  },
  "files": [
    "src/",
    "benchmark/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "security",
    "scanner",
    "sast",
    "predeploy",
    "mcp",
    "agent",
    "x402",
    "attestation",
    "vulnerability",
    "secrets",
    "injection",
    "supabase"
  ],
