{
  "name": "supership-scan",
  "version": "1.0.0",
  "description": "Predeploy security scanner for the agent economy. 80+ vulnerability patterns. Runs locally, code never leaves your machine.",
  "type": "module",
  "bin": {
    "supership-scan": "./src/cli.mjs",
    "supership-mcp": "./src/server.mjs"
  },
  "exports": {
    ".": "./src/scanner.mjs",
    "./mcp": "./src/server.mjs"
  },
  "scripts": {
