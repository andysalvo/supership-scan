  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/andysalvo/supership-scan.git"
  },
  "bugs": {
    "url": "https://github.com/andysalvo/supership-scan/issues"
  },
  "homepage": "https://supership.crestsystems.ai",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
